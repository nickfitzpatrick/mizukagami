# Copy to .env (gitignored) and fill in.

# Which model the agent uses: "ollama" (local, free) or "anthropic" (Claude API)
MIZUKAGAMI_MODEL_PROVIDER=ollama

# Local model tag (must be pulled in Ollama: `ollama pull llama3.1:8b`)
MIZUKAGAMI_OLLAMA_MODEL=llama3.1:8b

# Claude model + key (only needed when provider=anthropic)
MIZUKAGAMI_ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
